---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import type { Graph } from "schema-dts";
import StructuredData from "../../../components/StructuredData.astro";
import {
  CATALOG_REVIEW_DATE,
  REPOSITORY_URL,
  absoluteUrl,
  formattedCatalogReviewDate,
  toolEntryPath,
} from "../../../config/site";
import { CATEGORY_BY_ID } from "../../../data/categories";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { createToolEntryContent } from "../../../lib/toolEntryContent";

export async function getStaticPaths() {
  const tools = await getCollection("tools");
  return tools.map((tool) => ({ params: { id: tool.id }, props: { tool } }));
}

interface Props {
  tool: CollectionEntry<"tools">;
}

const { tool } = Astro.props as Props;
const category = CATEGORY_BY_ID.get(tool.data.category);
const allTools = await getCollection("tools");
const relatedTools = allTools
  .filter((entry) => entry.data.category === tool.data.category && entry.id !== tool.id)
  .sort((left, right) => left.data.name.localeCompare(right.data.name))
  .slice(0, 6);

if (!category) {
  throw new Error(`Unknown tool category: ${tool.data.category}`);
}

const entryContent = createToolEntryContent(tool.data, category);
const canonical = absoluteUrl(toolEntryPath(tool.id));
const categoryUrl = absoluteUrl(`/tools/${category.id}/`);
const breadcrumbId = `${canonical}#breadcrumb`;
const sourceHost = new URL(tool.data.url).hostname.replace(/^www\./, "");
const schema: Graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonical}#page`,
      url: canonical,
      name: `${tool.data.name} | Awesome MLSecOps`,
      description: entryContent.answer,
      dateModified: CATALOG_REVIEW_DATE,
      isPartOf: {
        "@type": "CollectionPage",
        "@id": `${categoryUrl}#page`,
        url: categoryUrl,
        name: `${category.name} evaluation guide`,
      },
      isBasedOn: [tool.data.url, category.readmeUrl],
      about: { "@id": `${canonical}#tool` },
      breadcrumb: { "@id": breadcrumbId },
    },
    {
      "@type": "Thing",
      "@id": `${canonical}#tool`,
      name: tool.data.name,
      description: tool.data.description,
      url: tool.data.url,
      mainEntityOfPage: { "@id": `${canonical}#page` },
    },
    {
      "@type": "BreadcrumbList",
      "@id": breadcrumbId,
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
        { "@type": "ListItem", position: 2, name: "Tool evaluation guides", item: absoluteUrl("/tools/") },
        { "@type": "ListItem", position: 3, name: category.name, item: categoryUrl },
        { "@type": "ListItem", position: 4, name: tool.data.name, item: canonical },
      ],
    },
  ],
};
---

<BaseLayout
  title={entryContent.title}
  description={entryContent.metaDescription}
  ogKey="tools"
  newsletterAtEnd={false}
  robots="noindex,follow"
>
  <StructuredData data={schema} />

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol class="shell">
      <li><a href="/">Home</a></li>
      <li><a href="/tools/">Tool guides</a></li>
      <li><a href={`/tools/${category.id}/`}>{category.shortName}</a></li>
      <li aria-current="page">{tool.data.name}</li>
    </ol>
  </nav>

  <section class="page-hero entry-hero">
    <div class="shell entry-hero-grid">
      <div>
        <p class="eyebrow">Directory context | {category.name}</p>
        <h1>{tool.data.name}</h1>
        <p>{tool.data.description}</p>
        <div class="button-row">
          <a class="button" href={tool.data.url} data-analytics-event="Tool Outbound">Visit first-party source</a>
          <a class="button-secondary" href={category.readmeUrl} data-analytics-event="Repo Outbound">View README source</a>
        </div>
      </div>
      <aside class="entry-source-panel">
        <p class="eyebrow">Source record</p>
        <dl class="catalog-facts">
          <div><dt>Host</dt><dd>{sourceHost}</dd></div>
          <div><dt>Category</dt><dd><a href={`/tools/${category.id}/`}>{category.shortName}</a></dd></div>
          <div><dt>Reviewed</dt><dd><time datetime={CATALOG_REVIEW_DATE}>{formattedCatalogReviewDate()}</time></dd></div>
          <div><dt>Indexing</dt><dd>Directory support page</dd></div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="content-section entry-context-section">
    <div class="shell entry-context-grid">
      <div>
        <div class="section-heading">
          <p class="eyebrow">Direct answer</p>
          <h2>What is {tool.data.name}?</h2>
        </div>
        <div class="entry-answer prose">
          <p>{entryContent.answer}</p>
          <blockquote>
            <p>{tool.data.description}</p>
            <cite>Neutral catalog description synchronized from the Awesome MLSecOps README</cite>
          </blockquote>
        </div>
      </div>
      <aside class="entry-boundary-note">
        <p class="eyebrow">Evidence boundary</p>
        <h2>What should this description not imply?</h2>
        <p>{entryContent.sourceStatement} The directory does not independently verify current capabilities, maintenance, licensing, or security effectiveness.</p>
        <p>Propose corrections through the <a href={REPOSITORY_URL}>Awesome MLSecOps repository</a>.</p>
      </aside>
    </div>
  </section>

  <section class="content-section">
    <div class="shell entry-evaluation-grid">
      <div class="section-heading">
        <p class="eyebrow">Before adoption</p>
        <h2>What should teams verify about {tool.data.name}?</h2>
        <p>Answer these questions from current first-party documentation and testing evidence rather than relying on the directory listing alone.</p>
      </div>
      <ol class="verification-list">
        {category.verificationQuestions.map((question, index) => (
          <li><span>{String(index + 1).padStart(2, "0")}</span><p>{question}</p></li>
        ))}
      </ol>
    </div>
  </section>

  {relatedTools.length > 0 && (
    <section class="content-section related-entry-section">
      <div class="shell">
        <div class="section-heading">
          <p class="eyebrow">Same evaluation guide</p>
          <h2>Related {category.shortName.toLowerCase()} entries</h2>
        </div>
        <ul class="related-entry-grid">
          {relatedTools.map((entry) => (
            <li><a href={toolEntryPath(entry.id)}><strong>{entry.data.name}</strong><span>{entry.data.description}</span></a></li>
          ))}
        </ul>
      </div>
    </section>
  )}
</BaseLayout>