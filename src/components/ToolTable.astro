---
import type { CollectionEntry } from "astro:content";
import { toolEntryPath } from "../config/site";

interface Props {
  tools: CollectionEntry<"tools">[];
  categoryId: string;
  categoryName: string;
}

const { tools, categoryId, categoryName } = Astro.props;
const sortedTools = [...tools].sort((left, right) => left.data.name.localeCompare(right.data.name));
const searchId = `catalog-search-${categoryId}`;
---

<div class="catalog-browser" data-tool-catalog>
  <div class="catalog-toolbar">
    <div class="catalog-search">
      <label for={searchId}>Search this category</label>
      <input id={searchId} type="search" placeholder={`Search ${categoryName.toLowerCase()}`} autocomplete="off" data-tool-search />
    </div>
    <output class="catalog-count" for={searchId} data-tool-count>{sortedTools.length} entries</output>
  </div>

  <div class="tool-grid" data-tool-grid>
    {sortedTools.map((tool) => {
      const sourceHost = new URL(tool.data.url).hostname.replace(/^www\./, "");
      const searchText = `${tool.data.name} ${tool.data.description} ${sourceHost}`.toLocaleLowerCase("en");
      return (
        <article class="tool-card" data-tool-entry data-search={searchText}>
          <div class="tool-card-heading">
            <span class="tool-source-domain">{sourceHost}</span>
            <h3><a href={toolEntryPath(tool.id)}>{tool.data.name}</a></h3>
          </div>
          <p>{tool.data.description}</p>
          <div class="tool-card-actions">
            <a href={toolEntryPath(tool.id)}>Directory context</a>
            <a href={tool.data.url} data-analytics-event="Tool Outbound">Visit source</a>
          </div>
        </article>
      );
    })}
  </div>

  <p class="catalog-empty" data-tool-empty hidden>No catalog entries match that search.</p>
</div>

<script>
  document.querySelectorAll("[data-tool-catalog]").forEach((catalog) => {
    if (!(catalog instanceof HTMLElement)) return;
    const search = catalog.querySelector("[data-tool-search]");
    const count = catalog.querySelector("[data-tool-count]");
    const empty = catalog.querySelector("[data-tool-empty]");
    const entries = [...catalog.querySelectorAll("[data-tool-entry]")];

    if (!(search instanceof HTMLInputElement) || !count || !(empty instanceof HTMLElement)) return;

    search.addEventListener("input", () => {
      const query = search.value.trim().toLocaleLowerCase("en");
      let visible = 0;

      entries.forEach((entry) => {
        if (!(entry instanceof HTMLElement)) return;
        const matches = !query || entry.dataset.search?.includes(query) === true;
        entry.hidden = !matches;
        if (matches) visible += 1;
      });

      count.textContent = query ? `${visible} of ${entries.length} entries` : `${entries.length} entries`;
      empty.hidden = visible !== 0;
    });
  });
</script>